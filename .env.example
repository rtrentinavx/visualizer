# These environment variables should be configured in your Vercel dashboard:
# Project Settings > Environment Variables
#
# For Vite, client-side vars MUST be prefixed with VITE_ to be exposed to the browser.

# Sentry DSN for error tracking and user feedback
# Get yours from: Sentry Project Settings > Client Keys (DSN)
VITE_SENTRY_DSN=

# Upstash Redis for cloud sync and AI rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
